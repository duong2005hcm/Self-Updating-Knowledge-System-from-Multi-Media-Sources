# Render Environment Variables for backend_node
# Set these in Render Dashboard -> Environment

NODE_ENV=production
JWT_SECRET=change_me_to_a_long_random_secret
RAG_PYTHON_URL=https://self-updating-knowledge-system-from.onrender.com
RAG_FORWARD_AUTHORIZATION=false
CONTACT_COLLECTION=advisory
CORS_ORIGINS=https://your-frontend.vercel.app

# Preferred on Render: full JSON service account string
FIREBASE_SERVICE_ACCOUNT={"type":"service_account", ...}

# Optional local fallback (not for Render)
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
